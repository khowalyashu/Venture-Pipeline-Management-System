# Database Configuration
DATABASE_URL=postgresql://app_miv:supersecret@localhost:5432/app_miv
DATABASE_PROVIDER=postgresql

# PostgreSQL Direct Connection (for docker-compose)
POSTGRES_USER=app_miv
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=app_miv

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
PUBLIC_BACKEND_URL=http://localhost:3001

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth — required for Google SSO on login & register pages
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origins : http://localhost:3000
# Authorised redirect URIs      : http://localhost:3000  (GSI uses postMessage, no redirect needed)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# IMPORTANT: the NEXT_PUBLIC_ prefix exposes the client ID to the browser (required for GIS button)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# AI Services (optional)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Node Environment
NODE_ENV=development
